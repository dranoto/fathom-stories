# --- Database ---
DATABASE_URL=sqlite:///./data/stories.db

# --- LLM (OpenAI-compatible; Gemini is NOT supported) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_SUMMARY_MODEL_NAME=gpt-4o-mini
DEFAULT_GROUPING_MODEL_NAME=gpt-4o-mini
SUMMARY_MAX_OUTPUT_TOKENS=8192
GROUPING_MAX_OUTPUT_TOKENS=4096
SUMMARY_LLM_TEMPERATURE=0.2
GROUPING_LLM_TEMPERATURE=0.1

# --- RSS Feeds (comma-separated or JSON list) ---
# Examples:
#   RSS_FEED_URLS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml
#   RSS_FEED_URLS=["https://feeds.bbci.co.uk/news/world/rss.xml","https://rss.nytimes.com/services/xml/rss/nyt/World.xml"]
RSS_FEED_URLS=

# --- Scheduler ---
DEFAULT_RSS_FETCH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_INDIVIDUAL_FEED=15
RECLUSTER_HOUR_UTC=3
LIFECYCLE_TICK_HOURS=1
AUTO_ARCHIVE_DAYS=7
ARCHIVE_REVIVE_WINDOW_DAYS=30

# --- Scraper / Playwright ---
PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
PLAYWRIGHT_TIMEOUT=60000
PLAYWRIGHT_PAGE_WAIT_MS=3000
SCRAPE_REQUEST_DELAY_SEC=1
USE_HEADLESS_BROWSER=True
# Leave empty to auto-detect ./scraper_assistant
PATH_TO_EXTENSION=

# --- Ports ---
MAIN_PORT=8000
ADMIN_PORT=8001

# --- Debug ---
DEBUG_LEVEL=standard
