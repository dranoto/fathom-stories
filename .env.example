# --- Database ---
DATABASE_URL=sqlite:///./data/stories.db

# --- LLM (OpenAI-compatible; Gemini is NOT supported) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_SUMMARY_MODEL_NAME=gpt-4o-mini
DEFAULT_GROUPING_MODEL_NAME=gpt-4o-mini
SUMMARY_MAX_OUTPUT_TOKENS=8192
GROUPING_MAX_OUTPUT_TOKENS=4096
SUMMARY_LLM_TEMPERATURE=0.2
GROUPING_LLM_TEMPERATURE=0.1

# --- RSS Feeds (comma-separated or JSON list) ---
# Examples:
#   RSS_FEED_URLS=https://feeds.bbci.co.uk/news/world/rss.xml,https://rss.nytimes.com/services/xml/rss/nyt/World.xml
#   RSS_FEED_URLS=["https://feeds.bbci.co.uk/news/world/rss.xml","https://rss.nytimes.com/services/xml/rss/nyt/World.xml"]
RSS_FEED_URLS=

# --- Scheduler ---
DEFAULT_RSS_FETCH_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_INDIVIDUAL_FEED=15
RECLUSTER_HOUR_UTC=3
LIFECYCLE_TICK_HOURS=1
AUTO_ARCHIVE_DAYS=7
ARCHIVE_REVIVE_WINDOW_DAYS=30

# --- Scraper / Playwright ---
PLAYWRIGHT_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
PLAYWRIGHT_TIMEOUT=60000
PLAYWRIGHT_PAGE_WAIT_MS=3000
SCRAPE_REQUEST_DELAY_SEC=1
USE_HEADLESS_BROWSER=True
# Leave empty to auto-detect ./scraper_assistant
PATH_TO_EXTENSION=

# --- Ports ---
MAIN_PORT=8800

# --- Summary prompts (optional overrides) ---
# The defaults are defined in app/config.py and used by app/grouping/summarizer.py.
#   DEFAULT_MAJOR_SUMMARY_PROMPT       — used for the initial event-level summary
#                                          and for full regenerations.
#                                          Placeholders: {event_name}, {article_texts}.
#   DEFAULT_SUMMARY_INCREMENTAL_PROMPT — used when 1+ new articles join an existing
#                                          event and the prior summary is updated.
#                                          Placeholders: {event_name}, {new_count},
#                                          {new_article_texts}, {prior_summary_json}.
# Uncomment + set to override. Keep the {{ ... }} double-braces around the inner
# JSON skeleton (and escape any other literal { or } as {{ or }}) so .format()
# still works at call time. The first call to summarize/regenerate will use
# whatever value is here. Note: prompts are read on process start, so after
# editing .env you'll need to restart `python -m app.cli serve` for the change
# to take effect.
#
# DEFAULT_MAJOR_SUMMARY_PROMPT=
# DEFAULT_SUMMARY_INCREMENTAL_PROMPT=

# --- Debug ---
DEBUG_LEVEL=standard

# --- Current working prompts (defaults, copy from app/config.py) ---
# These are the EXACT prompts that are currently active. Uncomment a line,
# edit, and copy to your .env to override. The prompts are read on process
# start (app/config.py: load_dotenv + os.getenv), so restart the server to
# apply any change.

# DEFAULT_MAJOR_SUMMARY_PROMPT="Given a collection of articles about {event_name}, analyze them and return a JSON response with three subsections:\n\nReturn EXACTLY this JSON structure (no markdown, no extra text):\n{{\n  \"timeline_narrative\": \"Chronological narrative of key developments, organized by date. Highlight the most significant moments.\",\n  \"cross_source_synthesis\": \"How do different sources cover this story differently? Note any conflicting angles, unique insights from specific outlets, or notable patterns in coverage.\",\n  \"progressive_summary\": \"What is NEW since the last summary (or if no previous summary, what are the most recent developments)? Focus on what the user most needs to know right now.\",\n  \"article_count\": <total number of articles analyzed>,\n  \"feed_count\": <number of unique feeds>,\n  \"date_range\": \"<earliest date> - <latest date>\",\n  \"key_developments\": [\"Milestone 1\", \"Milestone 2\", \"Milestone 3\"]\n}}\n\nArticles to analyze:\n{article_texts}\n\nReturn the JSON now:"

# DEFAULT_SUMMARY_INCREMENTAL_PROMPT="You are updating an existing event summary with {new_count} new article(s) about {event_name}.\n\nThere is a prior summary (JSON below) and {new_count} new article(s) to incorporate.\n\nTasks:\n  1. Update the timeline_narrative to include the new developments. Keep it chronological.\n  2. Update the cross_source_synthesis if the new article(s) add a new angle or conflict.\n  3. Update the progressive_summary to focus on what's NEW since the prior summary.\n  4. Update key_developments: keep the most important milestones (max 5).\n  5. Update article_count to the new total.\n\nReturn EXACTLY this JSON (no markdown, no extra text):\n{{\n  \"timeline_narrative\": \"...\",\n  \"cross_source_synthesis\": \"...\",\n  \"progressive_summary\": \"...\",\n  \"key_developments\": [\"...\", \"...\"],\n  \"article_count\": <int>,\n  \"feed_count\": <int>,\n  \"date_range\": \"<earliest> - <latest>\"\n}}\n\nPrior summary:\n{prior_summary_json}\n\nNew article(s) to incorporate:\n{new_article_texts}\n\nReturn the JSON now:"
